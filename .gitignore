# Gitignore for KMS Activation Script

# Operating System Files
.DS_Store
Thumbs.db

# PowerShell History
*.PSHistory

# Log files
*.log

# Temporary files
#
*.tmp

# Executables
*.exe
*.dll

# IDE and editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Package manager files
node_modules/
pnpm-lock.yaml
yarn.lock

# Output directories
/dist/
/build/

# Sensitive information (if any, though none expected for this script)
*.key
*.pem
*.pfx

# Other common files
*.bak
*.swp
